# ─────────────────────────────────────────────────────────────
# Clearway API environment
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins
CORS_ORIGIN=http://localhost:5173
# Public URL of the web app (used in invoice emails / OAuth redirects)
WEB_APP_URL=http://localhost:5173

# Database — Neon PostgreSQL (use the pooled connection string)
# https://neon.tech → project → Connection Details
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=clearway

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google / Gmail OAuth — https://console.cloud.google.com
# Scopes: gmail.readonly, gmail.send, gmail.modify
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/gmail/oauth/callback

# Company identity (printed on invoices / used as email sender)
COMPANY_NAME=NFK Exports (Pvt) Ltd
COMPANY_EMAIL=billing@nfkexports.com
COMPANY_ADDRESS=748-C, S.I.T.E., Karachi 75700, Pakistan
COMPANY_LOGO_URL=

# Invoice numbering
INVOICE_PREFIX=INV
# Default commission: FLAT | PERCENTAGE | PER_CONTAINER
DEFAULT_COMMISSION_TYPE=PER_CONTAINER
DEFAULT_COMMISSION_RATE=1400
