{
  "name": "clearway",
  "version": "0.1.0",
  "private": true,
  "description": "Clearway — logistics & customs brokerage operations platform (middleman invoicing automation).",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace web run build",
    "db:generate": "npm --workspace server run db:generate",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:seed": "npm --workspace server run db:seed",
    "lint": "npm --workspace web run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
